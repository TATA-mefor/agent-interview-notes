# ========================================
# Agent Interview Notes — 生产环境配置
# 复制此文件为 .env.production 并填入真实值
# ========================================

# --- 数据库 ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=agent_notes
DATABASE_URL=postgresql://postgres:your-strong-password-here@postgres:5432/agent_notes

# --- Next.js ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- LLM (可选，建议配一个) ---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-key
OPENAI_API_KEY=
ZHIPU_API_KEY=

# --- Ollama (可选) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- 应用 ---
NEXT_PUBLIC_APP_URL=https://agent-notes.example.com
NODE_ENV=production
