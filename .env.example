# 数据库连接（本地 PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_notes

# Supabase（可选，使用 Supabase 时填写）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM 供应商（至少配置一个才能使用 AI 功能，不配置时基础 CRUD 仍可用）
# 推荐: Dify (自建 LLM 平台) / DeepSeek (性价比高)
LLM_PROVIDER=dify

# Dify（自建 LLM 应用平台）
DIFY_API_URL=http://localhost:5001
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx

# 或使用直连 API:
# LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ZHIPU_API_KEY=

# Ollama 本地 LLM（可选，隐私优先方案）
OLLAMA_BASE_URL=http://localhost:11434
# Ollama embedding model（本地向量化，需先 ollama pull nomic-embed-text）
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI Embedding（使用 text-embedding-3-small，性价比高于 ada-002）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=512  # 可选，3-small 支持 512/1536

# 应用 URL（用于 PWA 和手机访问配置）
NEXT_PUBLIC_APP_URL=http://localhost:3000
